{
  "name": "aws-bedrock-lm-provider",
  "displayName": "AWS Bedrock Language Model Provider",
  "description": "Provides AWS Bedrock Claude models in the VS Code Copilot model picker",
  "version": "0.1.0",
  "publisher": "aws-bedrock-lm",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "enabledApiProposals": [
    "languageModelPricing"
  ],
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "bedrock",
        "displayName": "AWS Bedrock"
      }
    ],
    "configuration": {
      "title": "AWS Bedrock",
      "properties": {
        "awsBedrock.region": {
          "type": "string",
          "default": "us-east-1",
          "description": "AWS region for Bedrock API calls (used as geo-inference prefix).",
          "enum": [
            "us-east-1",
            "us-west-2",
            "eu-central-1",
            "eu-west-1",
            "ap-northeast-1",
            "ap-southeast-2"
          ]
        }
      }
    },
    "commands": [
      {
        "command": "awsBedrock.configure",
        "title": "AWS Bedrock: Configure API Key & Region"
      },
      {
        "command": "awsBedrock.updateApiKey",
        "title": "AWS Bedrock: Update API Key"
      },
      {
        "command": "awsBedrock.changeRegion",
        "title": "AWS Bedrock: Change Region"
      },
      {
        "command": "awsBedrock.refreshModels",
        "title": "AWS Bedrock: Refresh Model List"
      },
      {
        "command": "awsBedrock.resetCost",
        "title": "AWS Bedrock: Reset Cost Tracker"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "build:dev": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "compile": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.104.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.1079.0",
    "@aws-sdk/client-bedrock-runtime": "^3.600.0"
  }
}
